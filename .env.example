# City Data MCP — Required API Keys
# Copy this file to .env or set these as environment variables in Railway / Claude Desktop config

# US Census Bureau (demographics, permits)
# Sign up: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Federal Reserve Economic Data
# Sign up: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Bureau of Labor Statistics (employment data)
# Sign up: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# EPA Air Quality Index
# Sign up: https://docs.airnowapi.org/account/request/
AIRNOW_API_KEY=

# Optional — falls back to CENSUS_API_KEY if not set
# Sign up: https://api.data.gov/signup/
FBI_API_KEY=

# Google Civic Information (elected officials)
# Sign up: https://console.cloud.google.com/apis/credentials
GOOGLE_CIVIC_API_KEY=

# ── UK Data Sources ──

# UK Met Office DataPoint (weather)
# Sign up: https://www.metoffice.gov.uk/services/data/datapoint
UK_MET_OFFICE_API_KEY=

# UK EPC Register (energy performance certificates)
# Sign up: https://epc.opendatacommunities.org/login
UK_EPC_API_KEY=
UK_EPC_API_EMAIL=

# UK Transport for London
# Sign up: https://api-portal.tfl.gov.uk/
UK_TFL_API_KEY=

# UK Bus Open Data Service (national bus data)
# Sign up: https://data.bus-data.dft.gov.uk/
UK_BODS_API_KEY=

# UK TheyWorkForYou (elected representatives)
# Sign up: https://www.theyworkforyou.com/api/key
UK_TWFY_API_KEY=

# UK Ordnance Survey Data Hub (optional, for premium map features)
# Sign up: https://osdatahub.os.uk/
UK_OS_API_KEY=

# HTTP server port (only needed for --http mode, defaults to 3000)
# PORT=3000
